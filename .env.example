# Frontend environment — copy this file to `.env` (project root) and set the URL.
# `.env` is gitignored (never commit).

# Where the FastAPI backend is running. Point this at whoever is running the
# backend. On your own machine, run `ipconfig getifaddr en0` for your LAN IP.
# A phone must use the LAN IP (not localhost) and be on the same Wi-Fi.
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.100:8000
