# Backend environment — copy this file to `app/.env` and fill in the values.
# `app/.env` is gitignored (never commit real secrets).

# Key the mobile app sends in the X-API-KEY header. Keep it the same across
# the team so any app can talk to any teammate's backend.
FASTAPI_API_KEY=FASTAPI_P3

# Transcription (faster-whisper) and tagging (local keyword classifier) run
# entirely on the backend with NO API key and NO signup — nothing to add here.

# SMS alerts (Textbelt). Optional — leave blank to use the free shared key
# ('textbelt'), capped at 1 SMS/day globally (fine for a demo). Buy a real key
# at textbelt.com/purchase (~$0.01-0.04/text) for reliable delivery.
TEXTBELT_KEY=
